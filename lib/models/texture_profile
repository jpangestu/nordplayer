import 'dart:convert';

enum TextureType { asset, file }

class TextureProfile {
  final String id;    // 'glass', 'paper', 'custom_16322...'
  final String name;  // 'Frosted Glass', 'Imported Image'
  final String path;  // 'assets/glass.png' OR '/data/user/0/.../img.jpg'
  final TextureType type;

  const TextureProfile({
    required this.id,
    required this.name,
    required this.path,
    required this.type,
  });

  // --- SERIALIZATION LOGIC ---
  // Convert Object -> Map (for saving)
  Map<String, dynamic> toMap() {
    return {
      'id': id,
      'name': name,
      'path': path,
      'type': type.index, // Save enum as integer (0 or 1)
    };
  }

  // Convert Map -> Object (for loading)
  factory TextureProfile.fromMap(Map<String, dynamic> map) {
    return TextureProfile(
      id: map['id'],
      name: map['name'],
      path: map['path'],
      type: TextureType.values[map['type']], // Restore enum from integer
    );
  }

  // Helper for JSON encoding
  String toJson() => json.encode(toMap());

  // Helper for JSON decoding
  factory TextureProfile.fromJson(String source) => 
      TextureProfile.fromMap(json.decode(source));
  
  // Equality check is vital for Dropdowns to work correctly
  @override
  bool operator ==(Object other) =>
      identical(this, other) ||
      other is TextureProfile && runtimeType == other.runtimeType && id == other.id;

  @override
  int get hashCode => id.hashCode;
}